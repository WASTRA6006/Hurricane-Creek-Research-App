import { Router } from "express";
import { Photo } from "../types/photo.js";

const router = Router();

const photos: Photo[] = [
  { id: 1, zoneId: 1, category: "fauna", gpsAllowed: true, status: "approved" },
  { id: 2, zoneId: 2, category: "nature", gpsAllowed: false, status: "pending" },
  { id: 3, zoneId: 3, category: "flora", gpsAllowed: true, status: "rejected" },
];

router.get("/photos", (req, res) => {
  res.send(photos);
});

export default router;