import { Router } from "express";
import { Zone } from "../types/zone.js";

const router = Router();

const zones: Zone[] = [
  { id: 1, name: "Parking" },
  { id: 2, name: "Restoration Site" },
  { id: 3, name: "Chestnuts" },
];

router.get("/zones", (req, res) => {
  res.send(zones);
});

export default router;